# MongoDB Connection
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/agriflux

# Authentication
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRE=7d

# Firebase Admin SDK
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=your-client-email@project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Application Config
PORT=5001
NODE_ENV=production
FRONTEND_URL=https://agriflux.vercel.app
CITIZENONE_INTEGRATION_KEY=your_integration_key
