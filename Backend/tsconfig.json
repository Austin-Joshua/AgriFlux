{
    "compilerOptions": {
        "target": "ES2020",
        "module": "CommonJS",
        "outDir": "./dist",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "moduleResolution": "node",
        "rootDir": ".."
    },
    "include": [
        "src/**/*",
        "../Database/**/*"
    ],
    "exclude": [
        "node_modules"
    ]
}